{
  "openapi": "3.0.3",
  "info": {
    "title": "API Sistem Kasir Toko Bangunan Rukun Jaya",
    "description": "Dokumentasi interaktif POS & Ekosistem Manajemen Inventaris untuk Toko Bangunan Rukun Jaya.",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "https://be-rukun-jaya-production.up.railway.app/api/v1",
      "description": "Production Server (Railway)"
    },
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Development Server Lokal"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Masukkan token JWT"
      }
    }
  },
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "Autentikasi Pengguna",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "owner@toko-rukunjaya.com" },
                  "password": { "type": "string", "example": "password_rahasia" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login Berhasil" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/employees": {
      "get": {
        "summary": "Ambil Daftar Karyawan",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": { "description": "Daftar karyawan berhasil diambil" },
          "401": { "description": "Tidak memiliki otorisasi" },
          "403": { "description": "Role CASHIER ditolak akses" }
        }
      },
      "post": {
        "summary": "Tambah Karyawan",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "role"],
                "properties": {
                  "name": { "type": "string", "example": "Budi Santoso" },
                  "email": { "type": "string", "example": "[EMAIL_ADDRESS]" },
                  "password": { "type": "string", "example": "password123" },
                  "role": {"type": "string", "enum": ["CASHIER"]}
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Karyawan berhasil ditambahkan" },
          "401": { "description": "Anda tidak memiliki akses untuk menambahkan karyawan" },
          "403": { "description": "Role CASHIER ditolak akses" },
          "409": { "description": "Email sudah terdaftar" }
        }
      }
    },
    "/employees/{id}": {
      "put": {
        "summary": "Update Data Karyawan",
        "security": [{"BearerAuth": []}],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "Budi Santoso Edit" },
                  "email": { "type": "string", "example": "budi.edit@example.com" },
                  "password": { "type": "string", "example": "newpassword123" },
                  "role": { "type": "string", "enum": ["CASHIER", "OWNER"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Data karyawan berhasil diubah" },
          "401": { "description": "Tidak memiliki otorisasi" },
          "403": { "description": "Role CASHIER ditolak akses" },
          "404": { "description": "Data tidak ditemukan" }
        }
      },
      "delete": {
        "summary": "Hapus Karyawan",
        "security": [{"BearerAuth": []}],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Karyawan berhasil dihapus" },
          "401": { "description": "Tidak memiliki otorisasi" },
          "403": { "description": "Role CASHIER ditolak akses" },
          "404": { "description": "Data tidak ditemukan" }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "Ambil Daftar Produk",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "low_stock", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": { "description": "Daftar produk ditarik" }
        }
      },
      "post": {
        "summary": "Tambah Master Data Produk",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sku_code": { "type": "string", "example": "PIP-WV-AW12" },
                  "name": { "type": "string", "example": "Pipa Wavin AW 1/2 inch" },
                  "category_id": { "type": "string", "format": "uuid" },
                  "supplier_id": { "type": "string", "format": "uuid" },
                  "buy_price": { "type": "number", "example": 28000 },
                  "sell_price": { "type": "number", "example": 32000 },
                  "current_stock": { "type": "integer", "example": 120 },
                  "min_stock": { "type": "integer", "example": 50 },
                  "rack_location": { "type": "string", "example": "R-C3-12" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Produk berhasil ditambah" } }
      }
    },
    "/products/bulk-update": {
      "put": {
        "summary": "Bulk Update Stok Barang",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "updates": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "new_stock": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Update massal sukses" } }
      }
    },
    "/members/verify": {
      "get": {
        "summary": "Verifikasi Status Member VIP",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "phone", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Member ditemukan" },
          "404": { "description": "Member tidak ditemukan" }
        }
      }
    },
    "/transactions/checkout": {
      "post": {
        "summary": "Finalisasi Transaksi Penjualan (POS)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "member_id": { "type": "string", "nullable": true },
                  "discount_type": { "type": "string", "enum": ["NOMINAL", "PERCENTAGE"] },
                  "discount_value": { "type": "number" },
                  "cash_paid": { "type": "number" },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "product_id": { "type": "string", "format": "uuid" },
                        "quantity": { "type": "integer" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Transaksi sukses" } }
      }
    },
    "/transactions/export/excel": {
      "get": {
        "summary": "Export Transaksi ke Excel",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "start_date", "in": "query", "schema": { "type": "string", "example": "2026-06-01" } },
          { "name": "end_date", "in": "query", "schema": { "type": "string", "example": "2026-06-30" } }
        ],
        "responses": { "200": { "description": "File Excel terunduh" } }
      }
    },
    "/transactions/return": {
      "post": {
        "summary": "Retur Barang Cacat (Garansi Toko)",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "transaction_id": { "type": "string", "format": "uuid" },
                  "product_id": { "type": "string", "format": "uuid" },
                  "quantity_returned": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Retur berhasil" } }
      }
    },
    "/finance/summary": {
      "get": {
        "summary": "Ringkasan Laporan Keuangan",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "period", "in": "query", "schema": { "type": "string", "enum": ["this_month", "last_month", "custom"] } },
          { "name": "date_from", "in": "query", "schema": { "type": "string", "example": "2026-06-01" } },
          { "name": "date_to", "in": "query", "schema": { "type": "string", "example": "2026-06-30" } }
        ],
        "responses": { "200": { "description": "Data Ringkasan Keuangan" } }
      }
    },
    "/finance/export/pdf": {
      "get": {
        "summary": "Export Laporan Keuangan ke PDF",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "date_from", "in": "query", "schema": { "type": "string", "example": "2026-06-01" } },
          { "name": "date_to", "in": "query", "schema": { "type": "string", "example": "2026-06-30" } }
        ],
        "responses": { "200": { "description": "File PDF terunduh" } }
      }
    },
    "/dashboard/overview": {
      "get": {
        "summary": "Dashboard Overview (Agregasi Data)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "date", "in": "query", "schema": { "type": "string", "example": "2026-06-24" } }
        ],
        "responses": { "200": { "description": "Data Dashboard Overview" } }
      }
    },
    "/audit-logs": {
      "get": {
        "summary": "Log Audit",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "Daftar Audit Log" } }
      }
    },
    "/audit-logs/export/excel": {
      "get": {
        "summary": "Export Audit Logs ke Excel",
        "security": [{ "BearerAuth": [] }],
        "responses": { "200": { "description": "File Excel terunduh" } }
      }
    }
  }
}