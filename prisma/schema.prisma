// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- ENUMERATIONS ---

enum Role {
  OWNER
  CASHIER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum DiscountType {
  PERCENTAGE
  NOMINAL
}

// --- MODELS / TABLES ---

model User {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(255)
  email         String         @unique @db.VarChar(255)
  password_hash String         @db.VarChar(255)
  role          Role
  created_at    DateTime       @default(now()) @db.Timestamp
  transactions  Transaction[]
  audit_logs    AuditLog[]

  @@map("users")
}

model Member {
  id           String        @id @default(uuid()) @db.Uuid
  phone_number String        @unique @db.VarChar(50)
  name         String        @db.VarChar(255)
  status       MemberStatus  @default(ACTIVE)
  transactions Transaction[]

  @@map("members")
}

model Employee {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @db.VarChar(255)
  email       String        @unique @db.VarChar(255)
  password_hash String        @db.VarChar(255)
  role        Role
  created_at  DateTime      @default(now()) @db.Timestamp
  
  @@map("employees")
}

model Category {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @db.VarChar(255)
  products Product[]

  @@map("categories")
}

model Supplier {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(255)
  contact_info String?   @db.VarChar(255)
  products     Product[]

  @@map("suppliers")
}

model Product {
  id                  String              @id @default(uuid()) @db.Uuid
  sku_code            String              @unique @db.VarChar(100)
  name                String              @db.VarChar(255)
  category_id         String              @db.Uuid
  supplier_id         String              @db.Uuid
  buy_price           Decimal             @db.Decimal(12, 2)
  sell_price          Decimal             @db.Decimal(12, 2)
  current_stock       Int                 @default(0)
  defective_stock     Int                 @default(0)
  min_stock           Int                 @default(0)
  rack_location       String?             @db.VarChar(100)
  category            Category            @relation(fields: [category_id], references: [id], onDelete: Cascade)
  supplier            Supplier            @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  transaction_details TransactionDetail[]

  @@map("products")
}

model Transaction {
  id             String              @id @default(uuid()) @db.Uuid
  invoice_no     String              @unique @db.VarChar(100)
  cashier_id     String              @db.Uuid
  member_id      String?             @db.Uuid
  subtotal       Decimal             @db.Decimal(12, 2)
  discount_type  DiscountType        @default(NOMINAL)
  discount_value Decimal             @default(0) @db.Decimal(12, 2)
  tax_amount     Decimal             @default(0) @db.Decimal(12, 2)
  grand_total    Decimal             @db.Decimal(12, 2)
  cash_paid      Decimal             @db.Decimal(12, 2)
  change_amount  Decimal             @db.Decimal(12, 2)
  created_at     DateTime            @default(now()) @db.Timestamp
  cashier        User                @relation(fields: [cashier_id], references: [id], onDelete: Cascade)
  member         Member?             @relation(fields: [member_id], references: [id], onDelete: SetNull)
  details        TransactionDetail[]

  @@map("transactions")
}

model TransactionDetail {
  id             String      @id @default(uuid()) @db.Uuid
  transaction_id String      @db.Uuid
  product_id     String      @db.Uuid
  quantity       Int
  unit_price     Decimal     @db.Decimal(12, 2)
  subtotal       Decimal     @db.Decimal(12, 2)
  transaction    Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  product        Product     @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("transaction_details")
}

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String   @db.Uuid
  action          String   @db.VarChar(100)
  table_name      String   @db.VarChar(100)
  record_id       String?  @db.Uuid
  changes_payload Json     @db.JsonB
  created_at      DateTime @default(now()) @db.Timestamp
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}